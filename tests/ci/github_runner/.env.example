GITHUB_RUNNER_URL=https://github.com/radixark/miles
GITHUB_RUNNER_TOKEN=paste-your-token-here

# Host-side path to the miles CI data tree. Must exist on this host BEFORE
# `docker compose up -d`. The same path is used inside the runner container
# (identity bind mount) because the runner's --work path is forwarded to the
# host docker daemon via the mounted /var/run/docker.sock when it spawns
# sibling job containers; a mismatch would break that forwarding.
#
# scitix-72:    DATA_ROOT=/data
# novita-host*: DATA_ROOT=/mnt/nvme0n1
#
# If DATA_ROOT is unset, compose falls back to /data (the scitix-72 default).
DATA_ROOT=/data
