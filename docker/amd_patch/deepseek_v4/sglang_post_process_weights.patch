+    def post_process_weights(self, recv_req):
+        try:
+            from sglang.srt.model_loader.loader import device_loading_context
+
+            target_device = torch.device("cuda", torch.cuda.current_device())
+            if recv_req.restore_weights_before_load:
+                for module in self.model.modules():
+                    quant_method = getattr(module, "quant_method", None)
+                    restore_fn = getattr(
+                        quant_method, "restore_weights_before_loading", None
+                    )
+                    if restore_fn is not None:
+                        with device_loading_context(module, target_device):
+                            restore_fn(module)
+
+            if recv_req.post_process_quantization:
+                for module in self.model.modules():
+                    quant_method = getattr(module, "quant_method", None)
+                    process_fn = getattr(
+                        quant_method, "process_weights_after_loading", None
+                    )
+                    if process_fn is not None:
+                        with device_loading_context(module, target_device):
+                            process_fn(module)
+
+            if recv_req.post_load_weights:
+                post_load_fn = getattr(self.model, "post_load_weights", None)
+                if post_load_fn is not None:
+                    post_load_fn()
+
+            return True, "Succeeded to post-process weights."
+        except Exception as e:
+            error_msg = (
+                f"Failed to post-process weights: {e}. "
+                "The full weights of the ModelRunner may be partially updated. "
+                "Please discard the whole weights."
+            )
+            logger.error(error_msg)
+            return False, error_msg
